{
  "version": 2,
  "name": "gallery-games",
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "devCommand": "",
  "installCommand": "",
  "routes": [
    {
      "src": "/games/(.*)",
      "dest": "/games/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/archive/(.*)",
      "dest": "/archive/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
